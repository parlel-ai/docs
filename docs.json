{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Parlel",
  "description": "Documentation for the Parlel platform — AI-powered customer interactions, configured once, working across all AI interfaces.",
  "colors": {
    "primary": "#6B4EFF",
    "light": "#8B72FF",
    "dark": "#4B32E0"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "parlel.ai",
          "icon": "house",
          "href": "https://parlel.ai"
        },
        {
          "anchor": "Portal",
          "icon": "layout-dashboard",
          "href": "https://parlel.ai/portal"
        }
      ]
    },
    "groups": [
      {
        "group": "Start here",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "index",
          "how-parlel-works",
          "getting-started"
        ]
      },
      {
        "group": "Core concepts",
        "icon": "layers",
        "expanded": true,
        "pages": [
          "knowledge/knowledge-base",
          "actions/actions",
          "journeys/journeys",
          "authentication/authentication",
          "commercial/commercial-rules",
          "transactions/transactions",
          "fallbacks/fallback-flows"
        ]
      },
      {
        "group": "Platform",
        "icon": "plug",
        "expanded": true,
        "pages": [
          "integrations/integrations",
          "security/security"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Go to portal",
      "href": "https://parlel.ai/portal"
    }
  },
  "footer": {
    "socials": {
      "website": "https://parlel.ai",
      "linkedin": "https://linkedin.com/company/parlel-ai"
    }
  }
}
